# Discord credentials
DISCORD_BOT_TOKEN=          # Bot token from Discord Developer Portal
DISCORD_HOME_CHANNEL=       # Channel ID where Lulu listens without mention

# Notion (for portfolio building)
NOTION_API_KEY=             # Notion integration token (Internal Integration Secret)

# Gemini API (for video analysis)
# Google AI Studio 에서 발급: https://aistudio.google.com/apikey
# 기본은 무료 티어 (Gemini 2.5 Flash). Pro 는 billing 활성 후 사용 가능.
GEMINI_API_KEY=

# Memory directory (default: ~/Documents/Lulu_Memory)
# LULU_MEMORY_DIR=~/Documents/Lulu_Memory
